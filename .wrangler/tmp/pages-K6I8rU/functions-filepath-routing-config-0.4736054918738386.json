{
  "routes": [
    {
      "routePath": "/api/chat",
      "mountPath": "/api",
      "method": "OPTIONS",
      "module": [
        "api/chat.ts:onRequestOptions"
      ]
    },
    {
      "routePath": "/api/chat",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/chat.ts:onRequestPost"
      ]
    },
    {
      "routePath": "/api/push-subscribe",
      "mountPath": "/api",
      "method": "GET",
      "module": [
        "api/push-subscribe.ts:onRequestGet"
      ]
    },
    {
      "routePath": "/api/push-subscribe",
      "mountPath": "/api",
      "method": "OPTIONS",
      "module": [
        "api/push-subscribe.ts:onRequestOptions"
      ]
    },
    {
      "routePath": "/api/push-subscribe",
      "mountPath": "/api",
      "method": "POST",
      "module": [
        "api/push-subscribe.ts:onRequestPost"
      ]
    }
  ],
  "baseURL": "/"
}